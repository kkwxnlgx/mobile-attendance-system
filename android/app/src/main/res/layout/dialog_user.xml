<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView style="@style/FormLabel" android:layout_marginTop="0dp" android:text="角色" />
        <Spinner android:id="@+id/sp_role" android:layout_width="match_parent"
            android:layout_height="48dp" android:layout_marginTop="6dp"
            android:background="@drawable/bg_input" android:paddingStart="12dp" android:paddingEnd="12dp" />

        <EditText android:id="@+id/et_username" style="@style/FormInput"
            android:layout_marginTop="12dp" android:hint="账号（学号 / 工号）" android:inputType="text" />
        <EditText android:id="@+id/et_name" style="@style/FormInput"
            android:layout_marginTop="12dp" android:hint="姓名" android:inputType="text" />
        <EditText android:id="@+id/et_password" style="@style/FormInput"
            android:layout_marginTop="12dp" android:hint="初始密码（至少 6 位）" android:inputType="textPassword" />
        <EditText android:id="@+id/et_phone" style="@style/FormInput"
            android:layout_marginTop="12dp" android:hint="手机号（可选）" android:inputType="phone" />
    </LinearLayout>
</ScrollView>
