<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <include layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText android:id="@+id/et_old" style="@style/FormInput"
                android:layout_marginTop="0dp" android:hint="原密码" android:inputType="textPassword" />
            <EditText android:id="@+id/et_new" style="@style/FormInput"
                android:layout_marginTop="12dp" android:hint="新密码（至少 6 位）" android:inputType="textPassword" />
            <EditText android:id="@+id/et_confirm" style="@style/FormInput"
                android:layout_marginTop="12dp" android:hint="确认新密码" android:inputType="textPassword" />

            <Button android:id="@+id/btn_save" style="@style/PrimaryButton"
                android:layout_marginTop="24dp" android:text="保存" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
